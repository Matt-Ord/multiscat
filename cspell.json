{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "version": "0.2",
    "language": "en",
    "ignorePaths": [
        "**/.git/**",
        "**/.venv/**",
        "**/.pytest_cache/**",
        "**/.ruff_cache/**",
        "**/build/**",
        "**/*.egg-info/**",
        "**/*.f",
        "**/*.f90",
        "**/*.inc",
        "**/*.pyf",
        "**/PKG-INFO"
    ],
    "words": [
        "allclose",
        "arccos",
        "arctan",
        "asfortranarray",
        "barycentric",
        "bloch",
        "cflags",
        "cmdclass",
        "complexfloating",
        "diffrac",
        "diagsub",
        "eigenstates",
        "f2py",
        "fcflags",
        "fflags",
        "fromroots",
        "gmres",
        "imag",
        "ierr",
        "ijkl",
        "infty",
        "interp",
        "kohn",
        "ldflags",
        "linalg",
        "lobatto",
        "manolopoulos",
        "matplotlib",
        "matvec",
        "maxiter",
        "mcmodel",
        "multiscat",
        "newaxis",
        "nzlobatto",
        "numpy",
        "preconditioner",
        "pyproject",
        "pytest",
        "resid",
        "rtol",
        "scatsub",
        "scipy",
        "setuptools",
        "testpaths",
        "tqdm",
        "venv",
        "wavefunction",
        "wavevector",
        "wolken",
        "wyatt",
        "xlabel",
        "ylabel"
    ],
    "ignoreRegExpList": [
        "\\\\mathbf",
        "\\\\infty"
    ]
}